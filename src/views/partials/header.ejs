<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/main.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/login.css">
    <link rel="stylesheet" href="/css/family.css">
    <link rel="stylesheet" href="/css/modal.css">
    <link rel="stylesheet" href="/css/register.css">
    <link rel="stylesheet" href="/css/tasks.css">
    <link rel="stylesheet" href="/css/admin.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <header>
        <a href="/"><img src="/images/logo.png" alt="logo"></a>
        <nav>
            <ul>
                <% if (locals.isLoggedIn) { %>
                    <% if (currentUser && currentUser.role === 'parent') { %>
                        <li><a href="/">Home</a></li>
                    <% } %>
                    <% if (currentUser && (currentUser.role === 'parent' || currentUser.role === 'child')) { %>
                        <li><a href="/tasks">Tasks</a></li>
                        <li><a href="/family">My Family</a></li>
                    <% } %>

                    <% if (currentUser && currentUser.role === 'admin') { %>
                        <li><a href="/admin">Admin Dashboard</a></li>
                        <li><a href="/admin/users">Manage Users</a></li>
                        <li><a href="/admin/families">Manage Families</a></li>
                    <% } %>
                    <li>
                        <form method="POST" action="/logout">
                            <button type="submit" class="logout">Logout             <i class="bi bi-box-arrow-right"></i></button>
                        </form>
                    </li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </nav>
    </header>
<% const hasMessages = Object.values(locals.messages || {}).some(arr => arr.length > 0); %>
<% if (hasMessages) { %>
    <div class="flash-messages">
        <% Object.keys(locals.messages || {}).forEach(type => { %>
            <% locals.messages[type].forEach(message => { %>
                <div class="flash <%= type %>">
                    <%= message %>
                </div>
            <% }); %>
        <% }); %>
    </div>
<% } %>
<%- include('../partials/header') %>
    <main>

        <div class="login-content">

            <form method="POST" action="/register" class="login-form">
                <img class="login-logo" src="/images/logo.png" alt="logo">
                <h3>Sign Up</h3>
                <div class="form-group">
                    <label for="name">Name</label>
                    <input type="text" id="name" name="name" minlength="2" placeholder="Name" required>
                </div>

                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" required>
                </div>

                <div class="form-group"> 
                    <label for="emailConfirm">Confirm Email</label>
                    <input type="email" id="emailConfirm" name="emailConfirm" required>
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" id="password" name="password" required>
                    <div class="help-text">
                        Must be at least 8 characters with a number and special character.
                    </div>
                </div>

                <div class="form-group">
                    <label for="passwordConfirm">Confirm Password</label>
                    <input type="password" minlength="8" pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*" id="passwordConfirm" name="passwordConfirm" required>
                    <div class="help-text">
                        Must be at least 8 characters with a number and special character.
                    </div>
                </div>
                <div class="form-group">
                    <label>Are you joining or creating a family?</label>
                    <div class="family-toggle">
                        <button type="button" id="btn-join" class="toggle-btn active">Join a Family</button>
                        <button type="button" id="btn-create" class="toggle-btn">Create a Family</button>
                    </div>
                    <input type="hidden" name="familyAction" id="familyAction" value="join">
                </div>

                <div class="form-group" id="join-group">
                    <label for="invite_code">Invite Code</label>
                    <input type="text" id="invite_code" name="invite_code" placeholder="e.g. SMITH-A4B9" required>
                </div>

                <div class="form-group" id="create-group" style="display:none;">
                    <label for="family_name">Family Name</label>
                    <input type="text" id="family_name" name="family_name" placeholder="e.g. Smith" minlength="2">
                </div>
                
                <div class="form-group">
                    <button type="submit">Create Account</button>
                </div>

                <div class="form-footer">
                    <p>Already have an account? <a href="/login">Sign in</a></p>
                </div>
            </form>

            <div>
                <img class="login-image" src="/images/family-login.jpg">
            </div>
        </div>

    </main>
<%- include('../partials/footer') %>
<script>
    const btnJoin = document.getElementById('btn-join');
    const btnCreate = document.getElementById('btn-create');
    const joinGroup = document.getElementById('join-group');
    const createGroup = document.getElementById('create-group');
    const familyAction = document.getElementById('familyAction');

    const inviteInput = document.getElementById('invite_code');
    const familyNameInput = document.getElementById('family_name');

    btnJoin.addEventListener('click', () => {
        familyAction.value = 'join';
        joinGroup.style.display = 'block';
        createGroup.style.display = 'none';
        inviteInput.required = true;
        familyNameInput.required = false;
        btnJoin.classList.add('active');
        btnCreate.classList.remove('active');
    });

    btnCreate.addEventListener('click', () => {
        familyAction.value = 'create';
        joinGroup.style.display = 'none';
        createGroup.style.display = 'block';
        inviteInput.required = false;
        familyNameInput.required = true;
        btnCreate.classList.add('active');
        btnJoin.classList.remove('active');
    });
</script>